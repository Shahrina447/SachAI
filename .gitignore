# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
.installed.cfg
lib/
lib64/
MANIFEST

# ── Virtual Environments ──────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
/tmp/sachai_env/

# ── Environment Variables & Secrets ──────────────────────────
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.env
secrets.json
secrets.yaml
credentials.json
config.secret.*
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt

# ── ML Model Weights (large binary files) ────────────────────
backend/saved_model/
ml/results/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.pkl
*.pickle
# Exception: keep config files inside saved_model
!backend/saved_model/config.json
!backend/saved_model/tokenizer_config.json
!backend/saved_model/tokenizer.json
!backend/saved_model/special_tokens_map.json
!backend/saved_model/sentencepiece.bpe.model

# ── HuggingFace Cache ─────────────────────────────────────────
